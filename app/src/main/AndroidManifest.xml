<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.jiaweiya.hdamieviewer">

    <!-- 获取网络权限用于 GitHub 更新检查 -->
    <uses-permission android:name="android.permission.INTERNET" />

    <uses-permission android:name="android.permission.VIBRATE" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.HdamieViewer"
        android:enableOnBackInvokedCallback="true"
        tools:targetApi="tiramisu">

        <!-- 核心物理 Activity，不直接作为桌面入口 -->
        <activity
            android:name=".MainActivity"
            android:enabled="true"
            android:exported="true"
            android:theme="@style/Theme.HdamieViewer"
            android:windowSoftInputMode="adjustResize"
            android:configChanges="orientation|screenSize|screenLayout|smallestScreenSize" />

        <!-- 1. 默认图标入口（默认开启） -->
        <activity-alias
            android:name=".Alias1"
            android:enabled="true"
            android:exported="true"
            android:icon="@drawable/app_icon"
            android:label="@string/app_name"
            android:targetActivity=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <!-- 2. 图标 2（默认关闭） -->
        <activity-alias
            android:name=".Alias2"
            android:enabled="false"
            android:exported="true"
            android:icon="@drawable/app_icon2"
            android:label="@string/app_name"
            android:targetActivity=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <!-- 3. 图标 3（默认关闭） -->
        <activity-alias
            android:name=".Alias3"
            android:enabled="false"
            android:exported="true"
            android:icon="@drawable/app_icon3"
            android:label="@string/app_name"
            android:targetActivity=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <!-- 4. 图标 4（默认关闭） -->
        <activity-alias
            android:name=".Alias4"
            android:enabled="false"
            android:exported="true"
            android:icon="@drawable/app_icon4"
            android:label="@string/app_name"
            android:targetActivity=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <!-- 5. 图标 5（默认关闭） -->
        <activity-alias
            android:name=".Alias5"
            android:enabled="false"
            android:exported="true"
            android:icon="@drawable/app_icon5"
            android:label="@string/app_name"
            android:targetActivity=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <!-- 6. 图标 6（默认关闭） -->
        <activity-alias
            android:name=".Alias6"
            android:enabled="false"
            android:exported="true"
            android:icon="@drawable/app_icon6"
            android:label="@string/app_name"
            android:targetActivity=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

    </application>

</manifest>